# Made by Ali Alafandy

# for make a custom intro:
local videoSprite = "customVideo"; # change "customVideo" to "your video file name"

function onStartGame()
{
	"intro": true
}
end

function intro(path:string, offsets:float, scale:float)
{
	"path": "videos/" .. videoSprite,
	"offsets": [0, 0],
	"scale": [720, 1280]
}
end
