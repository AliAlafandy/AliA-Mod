# for load the character in the game:
local customChar = "charName"; # change "charName" to "your character file name"

function onLoadGame()
	{
		"charLoad": "characters/" .. customChar,
		"charNum": 0, # players: [0 = Ali, 1 = Hamedo, 2 = Zezo, 3 = Mohamed, 4 = Ali & Hamedo]
		"charOpen": false
	}
end